# ============================================================
# UDAAN Carpooling Platform — Environment Configuration
# Copy this to .env and adjust values for your setup
# ============================================================

# Database
DB_HOST=localhost
DB_NAME=carpooling_platform
DB_USER=root
DB_PASS=

# Application
APP_URL=http://localhost/CarPooling/public
APP_ENV=development
APP_DEBUG=true

# Maps Provider: leaflet or google
MAPS_PROVIDER=leaflet
GOOGLE_MAPS_KEY=

# Razorpay (Test Mode)
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXX
